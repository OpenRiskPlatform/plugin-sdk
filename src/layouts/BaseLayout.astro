---
import "../styles/globals.css";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "OpenRisk Plugin SDK", description = "Developer reference for OpenRisk plugin data model authors." } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const nav = [
  { href: base + "/", label: "Overview" },
  { href: base + "/entities/", label: "Entities" },
  { href: base + "/types/", label: "Types" },
  { href: base + "/manifest/", label: "Manifest" },
  { href: base + "/validate/", label: "Validator" },
];
const current = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · OpenRisk Plugin SDK</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={base + "/favicon.svg"} />
  </head>
  <body>
    <!-- Dark mode init: read localStorage before paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <!-- Top nav -->
    <header class="sticky top-0 z-40 border-b border-border bg-background/90 backdrop-blur">
      <div class="mx-auto flex h-14 max-w-6xl items-center gap-6 px-4">
        <a href={base + "/"} class="flex items-center gap-2 font-semibold text-sm">
          <span class="text-base">⬡</span>
          <span>OpenRisk SDK</span>
        </a>
        <nav class="flex items-center gap-1 text-sm">
          {nav.map((item) => {
            const isActive = current === item.href || (item.href !== base + "/" && current.startsWith(item.href));
            return (
              <a
                href={item.href}
                class={[
                  "px-3 py-1.5 rounded-md transition-colors",
                  isActive
                    ? "bg-accent text-accent-foreground font-medium"
                    : "text-muted-foreground hover:text-foreground hover:bg-accent/50",
                ].join(" ")}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
        <div class="ml-auto flex items-center gap-3">
          <a
            href="https://github.com/OpenRiskPlatform/plugin-sdk"
            target="_blank"
            rel="noreferrer"
            class="text-xs text-muted-foreground hover:text-foreground transition-colors"
          >
            GitHub ↗
          </a>
          <button
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="rounded-md p-1.5 text-muted-foreground hover:text-foreground hover:bg-accent/50 transition-colors"
          >
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </button>
        </div>
      </div>
    </header>

    <slot />

    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        var sun = document.getElementById("icon-sun");
        var moon = document.getElementById("icon-moon");
        function update() {
          var dark = document.documentElement.classList.contains("dark");
          sun.classList.toggle("hidden", !dark);
          moon.classList.toggle("hidden", dark);
        }
        update();
        btn.addEventListener("click", function () {
          var dark = document.documentElement.classList.toggle("dark");
          localStorage.setItem("theme", dark ? "dark" : "light");
          update();
        });
      })();
    </script>
  </body>
</html>
