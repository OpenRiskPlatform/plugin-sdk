---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { dataModelV001 } from "@model/data-model-v0.0.1.ts";

const base = import.meta.env.BASE_URL ?? "/plugin-sdk";
const entities = Object.values(dataModelV001.entities);
---

<BaseLayout title="Entities" description="All entity types in the OpenRisk data model.">
  <main class="mx-auto max-w-4xl px-4 py-12">
    <div class="mb-8">
      <a href={base + "/"} class="text-xs text-muted-foreground hover:text-foreground transition-colors">← Back</a>
      <h1 class="mt-2 text-3xl font-bold tracking-tight">Entities</h1>
      <p class="mt-2 text-muted-foreground">
        {entities.length} entity types in data model v{dataModelV001.version}
      </p>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      {entities.map((entity) => {
        const slug = entity.id.replace(/^entity\./, "");
        const propCount = Object.keys(entity.props).length;
        return (
          <a
            href={base + `/entities/${slug}/`}
            class="group flex flex-col gap-1.5 rounded-xl border border-border p-5 hover:border-primary/50 hover:bg-accent/30 transition-all"
          >
            <div class="flex items-center justify-between gap-2">
              <div class="flex items-center gap-2">
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">{entity.group}</span>
                <span class="text-muted-foreground">·</span>
                <span class="font-semibold text-sm">{entity.label}</span>
              </div>
              <span class={[
                "rounded-full px-2 py-0.5 text-xs font-medium",
                entity.frontend === "primary" ? "bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-300" : "bg-muted text-muted-foreground"
              ].join(" ")}>
                {entity.frontend}
              </span>
            </div>
            <p class="text-sm text-muted-foreground leading-snug">{entity.description}</p>
            <div class="flex items-center gap-3 text-xs text-muted-foreground font-mono">
              <span>{entity.id}</span>
              <span>·</span>
              <span>{propCount} props</span>
            </div>
          </a>
        );
      })}
    </div>
  </main>
</BaseLayout>
