---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { dataModelV002 } from "@model/data-model-v0.0.2.ts";
import { buildAllExamples } from "../../lib/buildExample.ts";
import { EntityPreview } from "../../components/EntityPreview.tsx";

export function getStaticPaths() {
  return Object.values(dataModelV002.entities).map((entity) => ({
    params: { slug: entity.id.replace(/^entity\./, "") },
    props: { entity },
  }));
}

const { entity } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const examples = buildAllExamples(entity);

// Group props by frontend tier
const primaryProps = Object.entries(entity.props).filter(([, p]) => p.frontend === "primary" || !p.frontend);
const extraProps = Object.entries(entity.props).filter(([, p]) => p.frontend === "extra");

const frontendLabel: Record<string, string> = {
  primary: "Rendered in card",
  extra: "Shown in extra section",
  generic: "Generic fallback",
  properties: "Shown in properties",
};
---

<BaseLayout title={entity.label} description={entity.description}>
  <main class="mx-auto max-w-5xl px-4 py-12">
    <!-- Breadcrumb -->
    <div class="mb-6 flex items-center gap-2 text-xs text-muted-foreground">
      <a href={base + "/"} class="hover:text-foreground transition-colors">SDK</a>
      <span>/</span>
      <a href={base + "/entities/"} class="hover:text-foreground transition-colors">Entities</a>
      <span>/</span>
      <span class="text-foreground font-medium">{entity.label}</span>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr_420px]">
      <!-- Left: Entity info -->
      <div>
        <!-- Header -->
        <div class="mb-8">
          <div class="flex items-start gap-3">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">{entity.group}</span>
                <span class={[
                  "rounded-full px-2 py-0.5 text-xs font-medium",
                  entity.frontend === "primary" ? "bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-300" : "bg-muted text-muted-foreground"
                ].join(" ")}>
                  {entity.frontend}
                </span>
              </div>
              <h1 class="text-3xl font-bold tracking-tight">{entity.label}</h1>
              <p class="mt-1 font-mono text-sm text-muted-foreground">{entity.id}</p>
            </div>
          </div>
          <p class="mt-4 text-muted-foreground leading-relaxed">{entity.description}</p>
          {entity.usage && (
            <div class="mt-4 rounded-lg border-l-4 border-primary/40 bg-muted/40 px-4 py-3">
              <p class="text-sm text-muted-foreground leading-relaxed">{entity.usage}</p>
            </div>
          )}
        </div>

        <!-- Props table -->
        <section class="mb-8">
          <h2 class="mb-3 text-base font-semibold">Properties</h2>
          <div class="overflow-x-auto rounded-xl border border-border">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="border-b border-border bg-muted/40">
                  <th class="px-3 py-2 text-left text-xs font-medium text-muted-foreground w-[160px]">Property</th>
                  <th class="px-3 py-2 text-left text-xs font-medium text-muted-foreground w-[180px]">Type</th>
                  <th class="px-3 py-2 text-left text-xs font-medium text-muted-foreground">Description</th>
                </tr>
              </thead>
              <tbody>
                {primaryProps.map(([key, prop]) => (
                  <tr class="border-b border-border/50 last:border-0 hover:bg-muted/20 transition-colors align-top">
                    <td class="px-3 py-2.5">
                      <div class="flex items-center gap-1 flex-wrap">
                        <code class="font-mono font-medium text-[13px]">{key}</code>
                        {prop.required && (
                          <span class="text-red-500 text-xs leading-none font-bold" title="required">*</span>
                        )}
                      </div>
                    </td>
                    <td class="px-3 py-2.5">
                      <div class="flex flex-wrap gap-1 items-center">
                        {prop.types.map((t) => (
                          <a
                            href={base + `/types/${t}/`}
                            class="rounded-md border border-border bg-muted px-1.5 py-0 text-[11px] font-mono hover:border-primary/50 hover:bg-accent transition-colors leading-5"
                          >
                            {t}
                          </a>
                        ))}
                        {prop.multiplicity === "many" && (
                          <span class="rounded-md bg-muted px-1.5 py-0 text-[11px] text-muted-foreground leading-5 font-mono" title="multiple values allowed">[ ]</span>
                        )}
                      </div>
                    </td>
                    <td class="px-3 py-2.5">
                      <p class="text-[13px] text-muted-foreground leading-snug">{prop.description}</p>
                      {prop.examples && prop.examples.length > 0 && (
                        <div class="mt-1.5 flex flex-wrap gap-1">
                          {prop.examples.slice(0, 3).map((ex) => (
                            <code class="rounded bg-muted px-1.5 py-0 text-[11px] font-mono text-muted-foreground leading-5">
                              {JSON.stringify(ex)}
                            </code>
                          ))}
                        </div>
                      )}
                      {prop.notes && (
                        <p class="mt-1 text-[11px] text-muted-foreground/70 italic">{prop.notes}</p>
                      )}
                    </td>
                  </tr>
                ))}
                {extraProps.length > 0 && (
                  <tr class="border-b border-border/30">
                    <td colspan={3} class="px-3 py-1.5 bg-muted/20">
                      <span class="text-[11px] font-medium text-muted-foreground uppercase tracking-wide">$extra fields</span>
                    </td>
                  </tr>
                )}
                {extraProps.map(([key, prop]) => (
                  <tr class="border-b border-border/30 last:border-0 hover:bg-muted/10 transition-colors align-top opacity-70">
                    <td class="px-3 py-2.5">
                      <code class="font-mono text-[13px]">{key}</code>
                    </td>
                    <td class="px-3 py-2.5">
                      <div class="flex flex-wrap gap-1">
                        {prop.types.map((t) => (
                          <span class="rounded-md border border-dashed border-border bg-muted px-1.5 py-0 text-[11px] font-mono text-muted-foreground leading-5">
                            {t}
                          </span>
                        ))}
                      </div>
                    </td>
                    <td class="px-3 py-2.5">
                      <p class="text-[13px] text-muted-foreground leading-snug">{prop.description}</p>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <!-- Right: Live Preview -->
      <div class="lg:sticky lg:top-20 lg:self-start">
        <h2 class="mb-3 text-base font-semibold">Preview</h2>
        <EntityPreview client:load examples={examples} />
      </div>
    </div>
  </main>
</BaseLayout>
